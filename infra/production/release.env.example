# Non-sensitive release inputs. Do not put runtime secrets in this file.
RELEASE_SHA=<40-character-commit-sha>
BACKEND_IMAGE=ghcr.io/<github-owner>/<repository>-backend
FRONTEND_IMAGE=ghcr.io/<github-owner>/<repository>-frontend
PAWCYCLE_RUNTIME_DIR=/opt/pawcycle/runtime
PAWCYCLE_STATE_DIR=/opt/pawcycle/state
