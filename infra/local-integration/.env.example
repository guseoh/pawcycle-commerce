# Copy this file to .env.local and replace every placeholder locally.
# .env.local is excluded by the repository root .gitignore.
MYSQL_DATABASE=<local-database-name>
MYSQL_USER=<local-database-user>
MYSQL_PASSWORD=<local-database-password>
MYSQL_ROOT_PASSWORD=<local-root-password>
PAWCYCLE_LOCAL_QA_BOOTSTRAP_EMAIL=<qa-foundation-004-email>
PAWCYCLE_LOCAL_QA_BOOTSTRAP_PASSWORD=<qa-foundation-004-password>
PAWCYCLE_LOCAL_QA_BOOTSTRAP_RESET_SUBSCRIPTIONS=false
PAWCYCLE_LOCAL_HTTP_PORT=8080
